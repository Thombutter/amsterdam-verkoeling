   "source": [
    "# Spatial join: per buurt bepalen hoeveel % binnen isochrone valt\n",
    "# Methode: area-weighted proportional population estimate\n",
    "\n",
    "print(\"\\nSpatial join: inwoners koppelen aan isochrones...\")\nresults = []\n\nfor t in WALK_TIMES:\n",
    "    iso_union = isochrone_gdfs[t].geometry.iloc[0]\n",
    "    \n",
    "    buurten_work = buurten.copy()\n",
    "    buurten_work[\"buurt_area\"] = buurten_work.geometry.area\n",
    "    \n",
    "    # Intersectie van elke buurt met de isochrone\n",
    "    buurten_work[\"intersect_area\"] = buurten_work.geometry.apply(\n",
    "        lambda g: g.intersection(iso_union).area if g.intersects(iso_union) else 0\n",
    "    )\n",
    "    \n",
    "    # Proportioneel aandeel inwoners binnen isochrone\n",
    "    buurten_work[\"coverage_pct\"] = (\n",
    "        buurten_work[\"intersect_area\"] / buurten_work[\"buurt_area\"]\n",
    "    ).fillna(0).clip(0, 1)  # Clip tussen 0 en 1\n",
    "    \n",
    "    buurten_work[f\"pop_{t}min\"] = buurten_work[POP_COL] * buurten_work[\"coverage_pct\"]\n",
    "    \n",
    "    total_in = buurten_work[f\"pop_{t}min\"].sum()\n",
    "    pct = (total_in / total_pop * 100) if total_pop > 0 else 0\n",
    "    \n",
    "    results.append({\"walk_time\": t, \"pop_with_access\": total_in, \"pct\": pct})\n",
    "    print(f\"  {t:2d} min: {total_in:>10,.0f} inwoners ({pct:5.1f}%) heeft toegang\")\n",
    "\n",
    "results_df = pd.DataFrame(results)\n",
    "print(\"\\n✓ Spatial join klaar\")"
   ]
