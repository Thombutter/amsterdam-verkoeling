   "source": [
    "---\n",
    "## Stap 2 – Wandelnetwerk ophalen\n",
    "\n",
    "We halen het wandelnetwerk van Amsterdam op via OSMnx.  \n",
    "Daarna voegen we looptijd toe als edge-attribuut (aanname: 83 meter/min ≈ 5 km/u)."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "print(\"Wandelnetwerk ophalen (dit duurt 1-2 minuten)...\")\n",
    "try:\n",
    "    G = ox.graph_from_place(CITY, network_type=\"walk\")\n",
    "    print(f\"✓ Netwerk geladen: {len(G.nodes)} knopen, {len(G.edges)} verbindingen\")\n",
    "except Exception as e:\n",
    "    raise ValueError(f\"Kan netwerk niet laden: {e}. Check je internet.\")\n",
    "\n",
    "# Loopsnelheid: 5 km/u = 83.3 meter per minuut\n",
    "WALK_SPEED_MPM = 83.3\n",
    "print(f\"Loopsnelheid: {WALK_SPEED_MPM:.1f} meter/minuut (5 km/u)\")\n",
    "\n",
    "# Voeg 'travel_time' toe aan elke edge (in minuten)\n",
    "for u, v, data in G.edges(data=True):\n",
    "    length = data.get(\"length\", 0)  # in meters\n",
    "    data[\"travel_time\"] = length / WALK_SPEED_MPM\n",
    "\n",
    "print(\"Travel time toegevoegd aan netwerk ✓\")"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "---\n",
    "## Stap 3 – Isochrones berekenen\n",
    "\n",
    "**Strategie:** Per verkoelende plek zoeken we het dichtstbijzijnde knooppunt in het netwerk (de 'ingang').  \n",
    "Vanuit dat knooppunt berekenen we welke andere knooppunten bereikbaar zijn binnen 5, 10 en 15 minuten lopen.  \n",
    "De convex hull van die knooppunten vormt de isochrone.\n",
    "\n",
    "> **Tip voor de presentatie:** Dit is een netwerkanalyse – geen simpele bufferzone. Een buffer houdt geen rekening met straten, water of obstakels. Een isochrone wel.\n",
    "\n",
    "---\n",
    "\n",
    "**⚠️ TEST-MODUS SELECTEREN:** Uncomment één van de onderstaande opties voor sneller testen of volledige analyse."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# TEST-MODUS SELECTIE\n",
    "# Kies één optie:\n",
    "\n",
    "# OPTIE 1: Snelle test (20 plekken) — max 2-3 minuten\n",
    "# cooling_used = cooling.sample(20, random_state=42).reset_index(drop=True)\n",
    "# print(\"🟡 TEST-MODUS: 20 verkoelende plekken\")\n",
    "\n",
    "# OPTIE 2: Volledige analyse (alle plekken) — 10-30 minuten afhankelijk van je machine\n",
    "cooling_used = cooling.reset_index(drop=True)\n",
    "print(f\"🟢 VOLLEDIGE ANALYSE: {len(cooling_used)} verkoelende plekken\")\n",
    "\n",
    "print(f\"Bereidende isochrones voor {len(cooling_used)} locaties...\")"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Knopen van het netwerk als GeoDataFrame\n",
    "nodes_gdf, _ = ox.graph_to_gdfs(G)\n",
    "nodes_gdf = nodes_gdf.to_crs(epsg=28992)\n",
    "print(f\"Netwerk knopen klaar: {len(nodes_gdf)} knopen\")\n",
    "\n",
    "# Centroides van verkoelende plekken als instappunten\n",
    "cooling_used[\"centroid\"] = cooling_used.geometry.centroid\n",
    "\n",
    "WALK_TIMES = [5, 10, 15]  # minuten\n",
    "\n",
    "def get_nearest_node(point, G):\n",
    "    \"\"\"Vind dichtstbijzijnde netwerkknooppunt voor een punt (in RD New).\"\"\"\n",
    "    try:\n",
    "        # OSMnx werkt met WGS84 voor nearest_nodes\n",
    "        point_wgs = gpd.GeoSeries([point], crs=28992).to_crs(4326).iloc[0]\n",
    "        return ox.nearest_nodes(G, point_wgs.x, point_wgs.y)\n",
    "    except Exception:\n",
    "        return None\n",
    "\n",
    "def isochrone_polygon(G, center_node, travel_time_min, nodes_gdf):\n",
    "    \"\"\"Bereken isochrone polygoon voor een knooppunt en reistijd.\"\"\"\n",
    "    try:\n",
    "        subgraph = nx.ego_graph(\n",
    "            G, center_node,\n",
    "            radius=travel_time_min,\n",
    "            distance=\"travel_time\"\n",
    "        )\n",
    "        node_ids = list(subgraph.nodes)\n",
    "        reachable = nodes_gdf[nodes_gdf.index.isin(node_ids)]\n",
    "        if len(reachable) < 3:\n",
    "            return None\n",
    "        return reachable.unary_union.convex_hull\n",
    "    except Exception:\n",
    "        return None\n",
    "\n",
    "print(\"Helper functions klaar ✓\")"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "print(f\"\\nIsochrones berekenen voor {len(cooling_used)} locaties...\")\n",
    "print(\"Dit kan 2-30 minuten duren (afhankelijk van aantal plekken)\\n\")\n",
    "\n",
    "isochrone_polys = {t: [] for t in WALK_TIMES}\n",
    "failed_count = 0\n",
    "\n",
    "for idx, row in tqdm(cooling_used.iterrows(), total=len(cooling_used), desc=\"Isochrones\"):\n",
    "    try:\n",
    "        center_node = get_nearest_node(row[\"centroid\"], G)\n",
    "        if center_node is None:\n",
    "            failed_count += 1\n",
    "            continue\n",
    "            \n",
    "        for t in WALK_TIMES:\n",
    "            poly = isochrone_polygon(G, center_node, t, nodes_gdf)\n",
    "            if poly is not None and poly.area > 0:\n",
    "                isochrone_polys[t].append(poly)\n",
    "    except Exception:\n",
    "        failed_count += 1\n",
    "        continue\n",
    "\n",
    "print(f\"\\n✓ Isochrones berekend\")\n",
    "if failed_count > 0:\n",
    "    print(f\"⚠️  {failed_count} plekken konden niet verwerkt worden\")\n",
    "\n",
    "# Samenvoegen per tijdstap (union = één groot gebied per tijdstap)\n",
    "isochrone_gdfs = {}\n",
    "for t in WALK_TIMES:\n",
    "    if len(isochrone_polys[t]) == 0:\n",
    "        raise ValueError(f\"Geen isochrones berekend voor {t} minuten!\")\n",
    "    \n",
    "    merged = unary_union(isochrone_polys[t])\n",
    "    isochrone_gdfs[t] = gpd.GeoDataFrame(\n",
    "        {\"walk_time\": [t], \"geometry\": [merged]},\n",
    "        crs=\"EPSG:28992\"\n",
    "    )\n",
    "    area_km2 = merged.area / 1_000_000\n",
    "    print(f\"  {t:2d} min: oppervlakte = {area_km2:6.2f} km²  |  {len(isochrone_polys[t])} polygonen geunieid\")"
   ]
  },
