   "source": [
    "# Kolommen standaardiseren\n",
    "print(\"\\nBeschikbare kolommen:\", list(buurten.columns)[:15])\n",
    "\n",
    "# Zoek bevolkingskolom\n",
    "POP_COL_OPTIONS = ['aant_inw', 'aantal_inwoners', 'AantInw', 'aantInwoners', 'BEV_DICHTH', 'bev_dichth']\n",
