   "source": [
    "# Risicogebieden berekenen: buurten met lage dekking bij 10 minuten\n",
    "# Dit zijn de buurten waar de gemeente mogelijk actie zou moeten ondernemen\n",
    "\n",
    "print(\"\\nRisicogebieden bepalen...\")\n",
    "\n",
    "iso_10 = isochrone_gdfs[10].geometry.iloc[0]\n",
    "\n",
    "buurten[\"buurt_area\"] = buurten.geometry.area\n",
    "buurten[\"intersect_10min\"] = buurten.geometry.apply(\n",
    "    lambda g: g.intersection(iso_10).area if g.intersects(iso_10) else 0\n",
    ")\n",
    "buurten[\"coverage_10min\"] = (\n",
    "    buurten[\"intersect_10min\"] / buurten[\"buurt_area\"]\n",
    ").fillna(0).clip(0, 1)\n",
    "\n",
    "# Risicogebied = minder dan 50% van de buurt is gedekt\n",
    "RISK_THRESHOLD = 0.5\n",
    "buurten[\"risk\"] = buurten[\"coverage_10min\"] < RISK_THRESHOLD\n",
    "\n",
    "risk_pop = buurten[buurten[\"risk\"]][POP_COL].sum()\n",
    "risk_buurten = len(buurten[buurten[\"risk\"]])\n",
    "\n",
    "print(f\"✓ Risicogebieden bepaald\")\n",
    "print(f\"  Buurten met < {RISK_THRESHOLD*100:.0f}% dekking: {risk_buurten}\")\n",
    "print(f\"  Inwoners in risicogebieden: {risk_pop:,.0f} ({risk_pop/total_pop*100:.1f}%)\")"
   ]
  },
